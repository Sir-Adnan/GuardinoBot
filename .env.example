# set log level: info, debug, warning, error
# LOG_LEVEL = "info"

# set Telegram bot's Token
BOT_TOKEN = ""

# public base url for payment callbacks / panel webhooks (REQUIRED)
WEBHOOK_BASE_URL = "http://your-server-ip:3333"
# optional override for externally reachable payment callback URLs
# PUBLIC_BASE_URL = "https://your-domain.com"

# --- Web admin/reseller panel (§9) ---
# JWT signing secret for the web panel. Leave empty to reuse SECRET_KEY_STRING.
# WEB_JWT_SECRET = ""
# Allowed CORS origins for the web-panel frontend ("*" or a comma-separated list)
# WEB_CORS_ORIGINS = "*"
# Domain the panel/bot are served on (set by the installer). Enables the
# in-bot "web panel" button + Telegram Web App auto-login. Requires HTTPS.
# DOMAIN = ""

# list of super users seperated by newlines
SUPER_USERS = "
123456789
987654321
"

# set proxy to use for telegram client
# PROXY = "socks5h://127.0.0.1:2080"

# set telegram parse mode, DO NOT CHANGE this if you don't know what you are doing
# PARSE_MODE = "HTML"


# SET database url - you can change port or the host(localhost) if needed
DATABASE_URL = "mysql://guardino:change_me@mariadb:3306/guardino"

# Set bot username, most probably will be overriden in runtime
BOT_USERNAME = "guardinobot"


# set default username prefix for created proxies
# usernames on the panel will be prefixed with this, for example: 'Guardino_c455d'
# DEFAULT_USERNAME_PREFIX = "Guardino"


# how many times each reseller can get test services by default
# DEFAULT_DAILY_TEST_SERVICES = 1


# all payments with a price more than this value will have 6 percent free credit
# PAYMENTS_DISCOUNT_ON = 400000
# PAYMENTS_DISCOUNT_ON_PERCENT = 6


# Channel id to send the transaction logs to (Bot must be admin in this channel)
# TRANSACTION_LOGS = "-1001892840123"


# perfectmoney credentials, DO NOT FORGET TO WHITLELIST YOUR IP IN PM'S API SETTINGS
# PERFECTMONEY_ACCOUNT_ID = ""
# PERFECTMONEY_PAYEE_ACCOUNT = "" 
# PERFECTMONEY_PASSPHRASE = ""


# nowpayments.io settings and credentials
# NP_API_URL = "https://api.nowpayments.io/v1"

# NP_API_KEY = ""

# the url that nowpayment will send the payment notifications to
# NP_IPN_CALLBACK_URL = "https://mybotserver.com/npipn/" # the path has to be '/npipn/'
# NP_IPN_SECRET_KEY = ""

# READ NOWPAYMENTS DOCS
# NP_SUCCESS_URL = ""
# NP_CANCEL_URL = ""
# Fixed pay coin for invoices (usdtbsc=BEP20 has low min/fee; usdttrc20=TRC20 is
# costly → "amountTo is too small"). Empty = customer picks on the page.
# NP_PAY_CURRENCY = "usdtbsc"

